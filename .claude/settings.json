{
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo test:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ],
    "deny": [
      "Bash(cargo build:*)",
      "Bash(cargo run:*)",
      "Bash(rm -rf:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./Cargo.lock)"
    ]
  },
  "effortLevel": "high",
  "editorMode": "vim",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
